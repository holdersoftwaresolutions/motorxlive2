generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  createdAt        DateTime @default(now())
  isActive         Boolean  @default(true)
  passwordHash     String
  updatedAt        DateTime @updatedAt
  role             UserRole @default(STREAMER)
  streamsSubmitted Stream[] @relation("StreamSubmittedBy")
  videosSubmitted  Video[]  @relation("VideoSubmittedBy")
}

model Category {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  sortOrder Int     @default(0)
  events    Event[]
}

model Event {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  startAt      DateTime?
  endAt        DateTime?
  heroImageUrl String?
  categoryId   String?
  description  String?
  addressLine1 String?
  city         String?
  country      String?
  latitude     Float?
  longitude    Float?
  postalCode   String?
  state        String?
  venueName    String?
  category     Category? @relation(fields: [categoryId], references: [id])
  streams      Stream[]
  videos       Video[]
}

model Stream {
  id                String                @id @default(cuid())
  eventId           String
  sourceType        StreamSourceType
  provider          String                @default("custom")
  title             String?
  isPrimary         Boolean               @default(false)
  priority          Int                   @default(0)
  playbackHlsUrl    String?
  playbackDashUrl   String?
  youtubeVideoId    String?
  lifecycle         StreamLifecycleStatus @default(CREATED)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  needsReview       Boolean               @default(true)
  submittedByUserId String?
  moderationStatus  ModerationStatus      @default(PENDING)
  rejectionReason   String?
  reviewedAt        DateTime?
  reviewedByUserId  String?
  event             Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submittedBy       User?                 @relation("StreamSubmittedBy", fields: [submittedByUserId], references: [id])

  @@index([eventId, priority])
}

model Video {
  id                String           @id @default(cuid())
  eventId           String
  submittedByUserId String?
  needsReview       Boolean          @default(true)
  sourceType        VideoSourceType
  provider          String           @default("custom")
  title             String
  description       String?
  playbackHlsUrl    String?
  playbackDashUrl   String?
  youtubeVideoId    String?
  durationSeconds   Int?
  status            VideoStatus      @default(PROCESSING)
  publishedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  moderationStatus  ModerationStatus @default(PENDING)
  rejectionReason   String?
  reviewedAt        DateTime?
  reviewedByUserId  String?
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submittedBy       User?            @relation("VideoSubmittedBy", fields: [submittedByUserId], references: [id])

  @@index([eventId])
  @@index([submittedByUserId])
}

enum UserRole {
  ADMIN
  STREAMER
  MEDIA
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VideoSourceType {
  MANAGED_VOD
  EXTERNAL_HLS
  YOUTUBE
}

enum VideoStatus {
  PROCESSING
  READY
  FAILED
  DISABLED
}

enum StreamSourceType {
  MANAGED_LIVE
  EXTERNAL_HLS
  YOUTUBE
}

enum StreamLifecycleStatus {
  CREATED
  READY
  LIVE
  ENDED
  DISABLED
  ERROR
}
