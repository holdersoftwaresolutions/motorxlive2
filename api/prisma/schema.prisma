generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  createdAt        DateTime @default(now())
  isActive         Boolean  @default(true)
  passwordHash     String
  updatedAt        DateTime @updatedAt
  role             UserRole @default(STREAMER)
  streamsSubmitted Stream[] @relation("StreamSubmittedBy")
  videosSubmitted  Video[]  @relation("VideoSubmittedBy")
}

model Category {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  sortOrder Int     @default(0)
  events    Event[]
}

model Event {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  startAt      DateTime?
  endAt        DateTime?
  heroImageUrl String?
  categoryId   String?
  description  String?
  addressLine1 String?
  city         String?
  country      String?
  latitude     Float?
  longitude    Float?
  postalCode   String?
  state        String?
  venueName    String?
  category     Category? @relation(fields: [categoryId], references: [id])
  streams      Stream[]
  videos       Video[]
}

model Stream {
  id                 String   @id @default(cuid())
  eventId           String
  title              String
  description        String?
  sourceType         StreamSourceType
  provider           String?
  sourceUrl          String?
  embedUrl           String?
  isPrimary         Boolean               @default(false)
  priority          Int                   @default(0)
  playbackHlsUrl    String?
  playbackDashUrl   String?
  lifecycle         StreamLifecycleStatus @default(CREATED)
  needsReview       Boolean               @default(true)
  submittedByUserId String?
  moderationStatus  ModerationStatus      @default(PENDING)
  rejectionReason   String?
  reviewedAt        DateTime?
  reviewedByUserId  String?
  event             Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submittedBy       User?                 @relation("StreamSubmittedBy", fields: [submittedByUserId], references: [id])
  youtubeVideoId     String?
  youtubeChannelId   String?
  youtubeChannelName String?
  youtubeThumbnailUrl String?
  youtubePublishedAt DateTime?
  youtubeScheduledStartTime DateTime?
  youtubeActualStartTime DateTime?
  youtubeActualEndTime DateTime?
  youtubeEmbeddable Boolean?
  youtubeLiveStatus String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([eventId, priority])
}

model Video {
  id                String           @id @default(cuid())
  eventId           String
  submittedByUserId String?
  needsReview       Boolean          @default(true)
  sourceType        VideoSourceType
  provider          String           @default("custom")
  title             String
  description       String?
  playbackHlsUrl    String?
  playbackDashUrl   String?
  youtubeVideoId    String?
  durationSeconds   Int?
  status            VideoStatus      @default(PROCESSING)
  publishedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  moderationStatus  ModerationStatus @default(PENDING)
  rejectionReason   String?
  reviewedAt        DateTime?
  reviewedByUserId  String?
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submittedBy       User?            @relation("VideoSubmittedBy", fields: [submittedByUserId], references: [id])

  @@index([eventId])
  @@index([submittedByUserId])
}

model YouTubeDiscoveredChannel {
  id                 String   @id @default(cuid())
  youtubeChannelId   String   @unique
  title              String
  description        String?
  thumbnailUrl       String?
  channelUrl         String?
  category           YouTubeChannelCategory @default(GENERAL_MOTORSPORTS)
  discoveryStatus    YouTubeDiscoveryStatus @default(DISCOVERED)
  score              Int      @default(0)
  scoreReasons       Json?
  recentLiveCount    Int      @default(0)
  upcomingLiveCount  Int      @default(0)
  completedLiveCount Int      @default(0)
  subscriberCount    Int?
  videoCount         Int?
  viewCount          Int?
  uploadsPlaylistId  String?
  autoIngestStreams  Boolean  @default(false)
  autoIngestVideos   Boolean  @default(false)
  autoIngestPodcasts Boolean  @default(false)
  isFeatured         Boolean  @default(false)
  priority           Int      @default(0)
  lastDiscoveredAt   DateTime @default(now())
  lastMonitoredAt    DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  videos             YouTubeDiscoveredVideo[]
}

model YouTubeDiscoveredVideo {
  id                   String   @id @default(cuid())
  youtubeVideoId        String   @unique
  youtubeChannelId      String
  channel               YouTubeDiscoveredChannel @relation(fields: [youtubeChannelId], references: [youtubeChannelId])
  title                 String
  description           String?
  thumbnailUrl          String?
  watchUrl              String
  embedUrl              String
  liveBroadcastContent  String?
  scheduledStartTime    DateTime?
  actualStartTime       DateTime?
  actualEndTime         DateTime?
  publishedAt           DateTime?
  embeddable            Boolean?
  duration              String?
  viewCount             Int?
  likeCount             Int?
  category              YouTubeChannelCategory?
  ingestionStatus       YouTubeIngestionStatus @default(DISCOVERED)
  motorXStreamId        String?
  motorXVideoId         String?
  score                 Int      @default(0)
  scoreReasons          Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model YouTubeApiUsageLog {
  id        String   @id @default(cuid())
  method    String
  quotaCost Int
  query     String?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  STREAMER
  MEDIA
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VideoSourceType {
  MANAGED_VOD
  EXTERNAL_HLS
  YOUTUBE
}

enum VideoStatus {
  PROCESSING
  READY
  FAILED
  DISABLED
}

enum StreamSourceType {
  MANAGED_LIVE
  EXTERNAL_HLS
  YOUTUBE
}

enum StreamLifecycleStatus {
  CREATED
  READY
  LIVE
  ENDED
  DISABLED
  ERROR
}

enum YouTubeDiscoveryStatus {
  DISCOVERED
  APPROVED
  IGNORED
  BLOCKED
}

enum YouTubeIngestionStatus {
  DISCOVERED
  READY_TO_INGEST
  INGESTED
  IGNORED
  FAILED
}

enum YouTubeChannelCategory {
  DRAG_RACING
  OFFROAD
  SXS_UTV
  MOTORSPORTS_PODCAST
  GENERAL_MOTORSPORTS
  TRACK_CHANNEL
  EVENT_PROMOTER
  CREATOR_MEDIA
}
